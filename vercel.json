{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/load", "destination": "/api/load.js" },
    { "source": "/api/save", "destination": "/api/save.js" },
    { "source": "/api/init-db", "destination": "/api/init-db.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
